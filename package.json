{
  "name": "erechnung",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:unit": "vitest --environment jsdom --root src/",
    "test:unit:ci": "vitest --watch false --environment jsdom --root src/",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint -c oxlintrc.json src/",
    "lint:fix": "oxlint -c oxlintrc.json --fix src/"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "dinero.js": "^2.0.0-alpha.17",
    "lucide-vue-next": "^0.577.0",
    "nanoid": "^5.1.7",
    "pinia": "^3.0.4",
    "swissqrbill": "^4.3.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/vite": "^4.2.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.51.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
