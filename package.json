{
  "name": "erechnung",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:unit": "vitest --environment jsdom --root src/",
    "test:unit:ci": "vitest --watch false --environment jsdom --root src/",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:all:css && bun run lint:all:formatting && bun run lint:all:js",
    "lint:all:css": "bun run lint:css -- 'src/**/*.{vue,scss,css}'",
    "lint:all:formatting": "bun run lint:formatting -- '**/*.{js,ts,json,css,scss,vue,html,md}'",
    "lint:formatting": "prettier --write --loglevel warn",
    "lint:all:js": "bun run lint:js -- --ext .js,.ts,.vue",
    "lint:js": "eslint --fix",
    "lint:css": "stylelint --fix",
    "lint:ci": "bun run lint"
  },
  "dependencies": {
    "@vueuse/core": "^9.12.0",
    "chart.js": "^4.5.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^2.0.29",
    "vue": "^3.2.45",
    "vue-i18n": "9"
  },
  "devDependencies": {
    "@playwright/test": "^1.30.0",
    "@rushstack/eslint-patch": "1.1.4",
    "@trivago/prettier-plugin-sort-imports": "3.3.0",
    "@types/jsdom": "20.0.1",
    "@types/node": "18.11.18",
    "@typescript-eslint/eslint-plugin": "5.35.1",
    "@typescript-eslint/parser": "5.35.1",
    "@vitejs/plugin-vue": "3.2.0",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "11.0.0",
    "@vue/test-utils": "2.2.7",
    "@vue/tsconfig": "0.1.3",
    "autoprefixer": "10.4.5",
    "eslint": "8.22.0",
    "eslint-plugin-vue": "9.4.0",
    "jsdom": "21.1.0",
    "npm-run-all": "4.1.5",
    "postcss": "8.4.19",
    "postcss-100vh-fix": "1.0.2",
    "postcss-html": "1.4.1",
    "postcss-import": "14.1.0",
    "prettier": "2.7.1",
    "stylelint": "14.16.1",
    "stylelint-config-prettier": "9.0.4",
    "stylelint-config-recommended-vue": "1.4.0",
    "stylelint-prettier": "2.0.0",
    "tailwindcss": "3.2.4",
    "ts-node": "10.9.1",
    "typescript": "4.9.4",
    "unplugin-auto-import": "0.14.2",
    "vite": "3.2.4",
    "vitest": "0.28.1"
  },
  "engines": {
    "node": ">=18"
  }
}
